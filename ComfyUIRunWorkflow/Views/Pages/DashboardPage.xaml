<Page
    x:Class="ComfyUIRunWorkflow.Views.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ComfyUIRunWorkflow.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:ComfyUIRunWorkflow.Models"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="DashboardPage"
    d:DataContext="{d:DesignInstance local:DashboardPage, IsDesignTimeCreatable=False}"
    d:DesignHeight="700"
    d:DesignWidth="1000"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16,8,16,16">

            <!-- タイトル -->
            <TextBlock
                Margin="0,0,0,12"
                FontSize="20"
                FontWeight="SemiBold"
                Text="ワークフロー実行" />

            <!-- ワークフロー選択 -->
            <Border
                Margin="0,0,0,8"
                Padding="12"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:SymbolIcon
                        Grid.Column="0"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        Symbol="Flow24" />
                    <TextBlock
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        FontSize="14"
                        Text="ワークフロー" />
                    <ComboBox
                        Grid.Column="2"
                        Width="200"
                        IsEnabled="{Binding ViewModel.IsConfigLoaded}"
                        ItemsSource="{Binding ViewModel.WorkflowNames, Mode=OneWay}"
                        SelectedItem="{Binding ViewModel.SelectedWorkflow, Mode=TwoWay}" />
                </Grid>
            </Border>

            <!-- プロンプト -->
            <Border
                Margin="0,0,0,8"
                Padding="12"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="4">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="13"
                        FontWeight="Medium"
                        Text="ポジティブプロンプト" />
                    <ui:TextBox
                        AcceptsReturn="True"
                        Height="80"
                        IsEnabled="{Binding ViewModel.IsConfigLoaded}"
                        PlaceholderText="masterpiece, best quality, ..."
                        Text="{Binding ViewModel.PositivePrompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="Wrap"
                        VerticalScrollBarVisibility="Auto" />
                    <TextBlock
                        Margin="0,8,0,4"
                        FontSize="13"
                        FontWeight="Medium"
                        Text="ネガティブプロンプト" />
                    <ui:TextBox
                        AcceptsReturn="True"
                        Height="60"
                        IsEnabled="{Binding ViewModel.IsConfigLoaded}"
                        PlaceholderText="worst quality, bad quality, ..."
                        Text="{Binding ViewModel.NegativePrompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="Wrap"
                        VerticalScrollBarVisibility="Auto" />
                </StackPanel>
            </Border>

            <!-- 画像サイズ -->
            <Border
                Margin="0,0,0,8"
                Padding="12"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="4">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,8"
                        FontSize="13"
                        FontWeight="Medium"
                        Text="画像サイズ" />
                    <WrapPanel>
                        <RadioButton
                            Margin="0,0,16,4"
                            Content="{Binding ViewModel.VerticalLabel, Mode=OneWay}"
                            IsChecked="{Binding ViewModel.IsVertical, Mode=TwoWay}"
                            IsEnabled="{Binding ViewModel.IsConfigLoaded}" />
                        <RadioButton
                            Margin="0,0,16,4"
                            Content="{Binding ViewModel.HorizontalLabel, Mode=OneWay}"
                            IsChecked="{Binding ViewModel.IsHorizontal, Mode=TwoWay}"
                            IsEnabled="{Binding ViewModel.IsConfigLoaded}" />
                        <RadioButton
                            Margin="0,0,16,4"
                            Content="{Binding ViewModel.SquareLabel, Mode=OneWay}"
                            IsChecked="{Binding ViewModel.IsSquare, Mode=TwoWay}"
                            IsEnabled="{Binding ViewModel.IsConfigLoaded}" />
                        <CheckBox
                            Margin="0,0,0,4"
                            Content="カスタム"
                            IsChecked="{Binding ViewModel.IsCustomSize, Mode=TwoWay}"
                            IsEnabled="{Binding ViewModel.IsConfigLoaded}" />
                    </WrapPanel>
                    <StackPanel
                        Margin="0,8,0,0"
                        Orientation="Horizontal"
                        Visibility="{Binding ViewModel.IsCustomSize, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            Text="Width" />
                        <ui:NumberBox
                            Width="80"
                            Margin="0,0,16,0"
                            Maximum="2048"
                            Minimum="512"
                            SpinButtonPlacementMode="Compact"
                            Value="{Binding ViewModel.CustomWidth, Mode=TwoWay}" />
                        <TextBlock
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            Text="Height" />
                        <ui:NumberBox
                            Width="80"
                            Maximum="2048"
                            Minimum="512"
                            SpinButtonPlacementMode="Compact"
                            Value="{Binding ViewModel.CustomHeight, Mode=TwoWay}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- LoRA -->
            <Border
                Margin="0,0,0,8"
                Padding="12"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="4">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,8"
                        FontSize="13"
                        FontWeight="Medium"
                        Text="LoRA（0〜4個）" />
                    <ItemsControl ItemsSource="{Binding ViewModel.LoraSlots}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:LoraSlot}">
                                <StackPanel Margin="0,0,8,4" Orientation="Horizontal">
                                    <ComboBox
                                        Width="160"
                                        IsEnabled="{Binding DataContext.ViewModel.IsConfigLoaded, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                        ItemsSource="{Binding DataContext.ViewModel.AvailableLoras, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                        SelectedItem="{Binding SelectedLora, Mode=TwoWay}" />
                                    <ui:Button
                                        Margin="4,0,0,0"
                                        Padding="4,0"
                                        Command="{Binding DataContext.ViewModel.RemoveLoraCommand, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                        CommandParameter="{Binding}"
                                        Appearance="Danger"
                                        Icon="{ui:SymbolIcon Dismiss12}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <ui:Button
                        Margin="0,4,0,0"
                        Command="{Binding ViewModel.AddLoraCommand}"
                        Content="+ 追加"
                        IsEnabled="{Binding ViewModel.IsConfigLoaded}"
                        Appearance="Secondary" />
                </StackPanel>
            </Border>

            <!-- 実行ボタン・進捗 -->
            <Border
                Padding="12"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="4">
                <StackPanel>
                    <ui:Button
                        HorizontalAlignment="Left"
                        Command="{Binding ViewModel.RunWorkflowCommand}"
                        Content="実行"
                        Appearance="Primary"
                        Icon="{ui:SymbolIcon Play24}" />
                    <ProgressBar
                        Margin="0,8,0,0"
                        Height="4"
                        IsIndeterminate="True"
                        Visibility="{Binding ViewModel.IsRunning, Converter={StaticResource BoolToVisibilityConverter}}" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
