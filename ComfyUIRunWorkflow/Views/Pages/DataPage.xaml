<Page
    x:Class="ComfyUIRunWorkflow.Views.Pages.DataPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ComfyUIRunWorkflow.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:ComfyUILibs.Models;assembly=ComfyUILibs"
    xmlns:wpfModels="clr-namespace:ComfyUIRunWorkflow.Models"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:helper="clr-namespace:ComfyUIRunWorkflow.Helpers"
    Title="DataPage"
    d:DataContext="{d:DesignInstance local:DataPage, IsDesignTimeCreatable=False}"
    d:DesignHeight="700"
    d:DesignWidth="1000"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    ScrollViewer.CanContentScroll="False"
    mc:Ignorable="d">

    <Page.Resources>
        <helper:ResultMessageConverter x:Key="ResultMessageConverter"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ヘッダー -->
        <Grid Grid.Row="0" Margin="16,8,16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Grid.Column="0"
                VerticalAlignment="Center"
                FontSize="20"
                FontWeight="SemiBold"
                Text="実行結果" />
            <ui:Button
                Grid.Column="1"
                Command="{Binding ViewModel.RefreshCommand}"
                Content="更新"
                Appearance="Secondary"
                Icon="{ui:SymbolIcon ArrowSync24}" />
        </Grid>

        <!-- 状態メッセージ -->
        <TextBlock
            Grid.Row="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            FontSize="14"
            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
            Text="{Binding ViewModel.StatusMessage}"
            Visibility="{Binding ViewModel.StatusMessage, Converter={StaticResource NullToVisibilityConverter}}" />

        <!-- 読み込み中インジケーター -->
        <ProgressBar
            Grid.Row="1"
            Height="4"
            VerticalAlignment="Top"
            IsIndeterminate="True"
            Visibility="{Binding ViewModel.IsLoading, Converter={StaticResource BoolToVisibilityConverter}}" />

        <!-- 結果リスト -->
        <ScrollViewer
            Grid.Row="1"
            Margin="16,0,16,16"
            VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding ViewModel.Results, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type wpfModels:WorkflowResultPreview}">
                        <Border
                            Margin="0,0,0,6"
                            Padding="12"
                            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Cursor="Hand">
                            <Border.InputBindings>
                                <MouseBinding
                                    Command="{Binding DataContext.ViewModel.OpenDetailCommand, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                    CommandParameter="{Binding Result}"
                                    MouseAction="LeftClick" />
                            </Border.InputBindings>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- ステータスアイコン -->
                                <Border
                                    Grid.Column="0"
                                    Width="32"
                                    Height="32"
                                    Margin="0,0,12,0"
                                    CornerRadius="16"
                                    VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Result.Status}" Value="success">
                                                    <Setter Property="Background" Value="{DynamicResource SystemFillColorSuccessBackgroundBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Result.Status}" Value="error">
                                                    <Setter Property="Background" Value="{DynamicResource SystemFillColorCriticalBackgroundBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Result.Status}" Value="success">
                                                        <Setter Property="Text" Value="✓" />
                                                        <Setter Property="Foreground" Value="{DynamicResource SystemFillColorSuccessBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Result.Status}" Value="error">
                                                        <Setter Property="Text" Value="✗" />
                                                        <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>

                                <!-- サムネイル -->
                                <Border
                                    Grid.Column="1"
                                    Width="48"
                                    Height="48"
                                    Margin="0,0,12,0"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    CornerRadius="4"
                                    Visibility="{Binding Preview, Converter={StaticResource NullToVisibilityConverter}}">
                                    <Grid>
                                        <Image
                                            Stretch="UniformToFill"
                                            Source="{Binding Preview.Thumbnail}"
                                            Visibility="{Binding Preview.Thumbnail, Converter={StaticResource NullToVisibilityConverter}}" />
                                        <ui:SymbolIcon
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="18"
                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                            Symbol="ImageOff24"
                                            Visibility="{Binding Preview.HasError, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    </Grid>
                                </Border>

                                <!-- 情報 -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock
                                        FontSize="13"
                                        FontWeight="Medium"
                                        Text="{Binding Result.Timestamp}" />
                                    <!-- 成功時: 出力ファイル名, エラー時: エラーメッセージ -->
                                    <TextBlock
                                        FontSize="12"
                                        TextTrimming="CharacterEllipsis"
                                        Text="{Binding Result, Converter={StaticResource ResultMessageConverter}}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Result.Status}" Value="success">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Result.Status}" Value="error">
                                                        <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
