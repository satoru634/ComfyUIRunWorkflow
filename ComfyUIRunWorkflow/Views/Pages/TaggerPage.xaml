<Page
    x:Class="ComfyUIRunWorkflow.Views.Pages.TaggerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ComfyUIRunWorkflow.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="TaggerPage"
    d:DataContext="{d:DesignInstance local:TaggerPage, IsDesignTimeCreatable=False}"
    d:DesignHeight="800"
    d:DesignWidth="1000"
    AllowDrop="True"
    Drop="OnDrop"
    DragOver="OnDragOver"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="380" />
            <ColumnDefinition Width="340" />
        </Grid.ColumnDefinitions>

        <!-- 左: 画像選択・実行 -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16,8,8,16">

                <!-- タイトル -->
                <TextBlock
                    Margin="0,0,0,12"
                    FontSize="20"
                    FontWeight="SemiBold"
                    Text="WD14 Tagger" />

                <!-- 画像選択・プレビュー -->
                <Border
                    Margin="0,0,0,8"
                    Padding="12"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                FontSize="13"
                                FontWeight="Medium"
                                Text="画像（ファイル選択 または ドラッグ＆ドロップ）" />
                            <ui:Button
                                Grid.Column="1"
                                Command="{Binding ViewModel.BrowseImageCommand}"
                                Content="画像を選択"
                                Appearance="Secondary"
                                Icon="{ui:SymbolIcon FolderOpen16}" />
                        </Grid>

                        <Border
                            Height="300"
                            Margin="0,8,0,0"
                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="4">
                            <Grid>
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    Text="ここに画像をドラッグ＆ドロップ"
                                    Visibility="{Binding ViewModel.SelectedImagePreview, Converter={StaticResource NullToVisibilityInverseConverter}}" />
                                <Image
                                    Margin="8"
                                    Source="{Binding ViewModel.SelectedImagePreview}"
                                    Stretch="Uniform"
                                    Visibility="{Binding ViewModel.SelectedImagePreview, Converter={StaticResource NullToVisibilityConverter}}" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- 実行ボタン・進捗 -->
                <Border
                    Padding="12"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                    <StackPanel>
                        <ui:Button
                            HorizontalAlignment="Left"
                            Command="{Binding ViewModel.TagImageCommand}"
                            Content="タグ付け実行"
                            Appearance="Primary"
                            Icon="{ui:SymbolIcon TextGrammarWand24}" />
                        <ProgressBar
                            Margin="0,8,0,0"
                            Height="4"
                            IsIndeterminate="True"
                            Visibility="{Binding ViewModel.IsRunning, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- 右: タグ結果 -->
        <Border
            Grid.Column="1"
            Margin="0,8,16,16"
            Padding="12"
            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Margin="0,0,0,8"
                    FontSize="13"
                    FontWeight="Medium"
                    Text="タグ結果" />

                <TextBlock
                    Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="12"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Text="タグ付けを実行すると&#x0a;ここに結果が表示されます"
                    TextAlignment="Center"
                    Visibility="{Binding ViewModel.HasResult, Converter={StaticResource BoolToVisibilityInverseConverter}}" />

                <ui:TextBox
                    Grid.Row="1"
                    AcceptsReturn="True"
                    IsReadOnly="True"
                    Text="{Binding ViewModel.ResultTags, Mode=OneWay}"
                    TextWrapping="Wrap"
                    VerticalScrollBarVisibility="Auto"
                    Visibility="{Binding ViewModel.HasResult, Converter={StaticResource BoolToVisibilityConverter}}" />

                <ui:Button
                    Grid.Row="2"
                    Margin="0,8,0,0"
                    HorizontalAlignment="Stretch"
                    Command="{Binding ViewModel.CopyTagsCommand}"
                    Content="コピー"
                    Appearance="Secondary"
                    Icon="{ui:SymbolIcon Copy16}"
                    Visibility="{Binding ViewModel.HasResult, Converter={StaticResource BoolToVisibilityConverter}}" />
            </Grid>
        </Border>

    </Grid>
</Page>
