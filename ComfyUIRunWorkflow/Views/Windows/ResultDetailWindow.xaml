<ui:FluentWindow
    x:Class="ComfyUIRunWorkflow.Views.Windows.ResultDetailWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="実行結果詳細"
    Width="600"
    Height="500"
    MinWidth="480"
    MinHeight="360"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    ExtendsContentIntoTitleBar="True"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar
            Grid.Row="0"
            Title="実行結果詳細"
            CloseWindowByDoubleClickOnIcon="False" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16,8,16,16">

                <!-- ステータス -->
                <Border
                    Margin="0,0,0,12"
                    Padding="12,8"
                    CornerRadius="4">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Status}" Value="success">
                                    <Setter Property="Background" Value="{DynamicResource SystemFillColorSuccessBackgroundBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="error">
                                    <Setter Property="Background" Value="{DynamicResource SystemFillColorCriticalBackgroundBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock FontSize="15" FontWeight="SemiBold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Status}" Value="success">
                                            <Setter Property="Text" Value="✓ 成功" />
                                            <Setter Property="Foreground" Value="{DynamicResource SystemFillColorSuccessBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="error">
                                            <Setter Property="Text" Value="✗ エラー" />
                                            <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock
                            Margin="0,2,0,0"
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="{Binding Timestamp}" />
                    </StackPanel>
                </Border>

                <!-- エラーメッセージ -->
                <Border
                    Margin="0,0,0,12"
                    Padding="10"
                    Background="{DynamicResource SystemFillColorCriticalBackgroundBrush}"
                    CornerRadius="4"
                    Visibility="{Binding Error, Converter={StaticResource NullToVisibilityConverter}}">
                    <TextBlock
                        FontSize="13"
                        Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                        Text="{Binding Error}"
                        TextWrapping="Wrap" />
                </Border>

                <!-- プロンプト -->
                <TextBlock
                    Margin="0,0,0,4"
                    FontSize="13"
                    FontWeight="Medium"
                    Text="ポジティブプロンプト" />
                <TextBox
                    Margin="0,0,0,8"
                    FontSize="12"
                    IsReadOnly="True"
                    MaxHeight="100"
                    Text="{Binding Parameters.Positive, Mode=OneWay}"
                    TextWrapping="Wrap"
                    VerticalScrollBarVisibility="Auto" />

                <TextBlock
                    Margin="0,0,0,4"
                    FontSize="13"
                    FontWeight="Medium"
                    Text="ネガティブプロンプト" />
                <TextBox
                    Margin="0,0,0,12"
                    FontSize="12"
                    IsReadOnly="True"
                    MaxHeight="80"
                    Text="{Binding Parameters.Negative, Mode=OneWay}"
                    TextWrapping="Wrap"
                    VerticalScrollBarVisibility="Auto" />

                <!-- 画像サイズ -->
                <TextBlock
                    Margin="0,0,0,4"
                    FontSize="13"
                    FontWeight="Medium"
                    Text="画像サイズ" />
                <TextBlock
                    Margin="0,0,0,12"
                    FontSize="13">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0} × {1}">
                            <Binding Path="Parameters.ImageSize.Width" />
                            <Binding Path="Parameters.ImageSize.Height" />
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>

                <!-- LoRA -->
                <TextBlock
                    Margin="0,0,0,4"
                    FontSize="13"
                    FontWeight="Medium"
                    Text="LoRA" />
                <ItemsControl
                    Margin="0,0,0,12"
                    ItemsSource="{Binding Parameters.Loras}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock FontSize="13">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0}  ({1},  強度: {2})">
                                        <Binding Path="Name" />
                                        <Binding Path="File" />
                                        <Binding Path="Strength" StringFormat="F2" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 出力ファイル -->
                <TextBlock
                    Margin="0,0,0,4"
                    FontSize="13"
                    FontWeight="Medium"
                    Text="出力ファイル" />
                <ItemsControl ItemsSource="{Binding Outputs}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock FontSize="13" Text="{Binding Filename}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 閉じるボタン -->
                <ui:Button
                    Margin="0,16,0,0"
                    HorizontalAlignment="Right"
                    Click="OnCloseClick"
                    Content="閉じる"
                    Appearance="Secondary" />

            </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>
